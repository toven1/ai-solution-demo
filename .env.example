# and live PG credentials are ready.
BILLING_PROVIDER="mock"
PG_PROVIDER="mock"
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
PORTONE_STORE_ID=""
PORTONE_CHANNEL_KEY=""

# Optional local-only test admin seed. Do not commit real values.
TEST_ADMIN_EMAIL=""
TEST_ADMIN_PASSWORD=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
